{
  "name": "gtd-flow",
  "version": "0.1.2",
  "description": "GTD Flow self-hosted task manager and native desktop client",
  "author": "GTD Flow",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run build:worker",
    "build:worker": "esbuild worker/reminders.ts --bundle --platform=node --format=esm --outfile=dist-worker/reminders.mjs",
    "start": "next start",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --test tests/rendered-html.test.mjs tests/desktop-badge.test.mjs",
    "desktop:dev": "electron desktop",
    "desktop:pack": "electron-builder --projectDir desktop --dir --win",
    "desktop:dist": "electron-builder --projectDir desktop --win nsis",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "0.31.10",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "type": "module"
}
