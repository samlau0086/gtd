DOMAIN=gtd.example.com
POSTGRES_DB=gtdflow
POSTGRES_USER=gtdflow
POSTGRES_PASSWORD=replace-with-a-long-hex-password
DATABASE_URL=postgresql://gtdflow:replace-with-a-long-random-password@localhost:5432/gtdflow
DB_POOL_SIZE=10

# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-at-least-32-random-bytes
# Generate with: openssl rand -base64 32
AI_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
MAIL_FROM="GTD Flow <mailer@example.com>"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
